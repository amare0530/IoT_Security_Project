{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "IoT: Create Venv",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "venv",
        ".venv"
      ],
      "problemMatcher": []
    },
    {
      "label": "IoT: Install Dependencies",
      "type": "shell",
      "command": "./.venv/Scripts/python.exe",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "problemMatcher": []
    },
    {
      "label": "IoT: Start Streamlit App",
      "type": "shell",
      "command": "./.venv/Scripts/python.exe",
      "args": [
        "-m",
        "streamlit",
        "run",
        "app.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "IoT: Start Node Device",
      "type": "shell",
      "command": "./.venv/Scripts/python.exe",
      "args": [
        "node.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "IoT: Start MQTT Bridge",
      "type": "shell",
      "command": "./.venv/Scripts/python.exe",
      "args": [
        "mqtt_bridge.py"
      ],
      "problemMatcher": []
    }
  ]
}
